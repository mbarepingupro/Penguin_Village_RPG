# Copy to .env and fill in real values. Loaded via python-dotenv (load_dotenv()) in app.py.

# Flask session signing key
SECRET_KEY=change-me

# Twitch OAuth (login) + Helix API (islive / stream presence)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=
# App access token used for server-to-server Helix calls (GET /islive, _stream_is_live()).
TWITCH_APP_TOKEN=

# Discord OAuth (login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Mayor dashboard access key (query/body "key" param, see _is_mayor_authed())
MAYOR_KEY=

# Shared secret for admin-only routes (e.g. /titles/grant), sent as the
# X-Admin-Secret header.
ADMIN_SECRET=

# Shared secret StreamerBot must send as the X-StreamerBot-Secret header on
# POST /seals/award, POST /stream/presence, and POST /stream/chatted. Must
# match exactly whatever value StreamerBot's outgoing HTTP action is
# configured to send in that header — these routes are otherwise open to
# anyone who can reach the server.
#
# Also reused as the X-Game-Secret header value on outbound calls the game
# makes to StreamerBot (see notify_streamerbot() in app.py) — one secret
# authenticates both directions. That's a deliberate tradeoff flagged in
# code, not a default to assume is fine: a leak on either side compromises
# both directions, and rotating it means updating both flows together.
STREAMERBOT_SECRET=

# URL of StreamerBot's inbound HTTP trigger/webhook that the game POSTs
# plain-text messages to (see notify_streamerbot() in app.py, used by
# POST /events/share/<id> and POST /card/<username>/share). This is the
# opposite direction from STREAMERBOT_SECRET's other use above — StreamerBot
# is the receiver here, not the sender.
STREAMERBOT_OUTBOUND_URL=

# Base64-encoded shared secret from the Twitch Developer Console (Extensions
# -> your extension -> Settings), used to verify the Extension Helper JWT
# (HS256) sent by the Twitch Extension panel frontend on every /extension/*
# request. See _extension_authed() / @extension_required in app.py.
EXTENSION_SECRET=

# Allowed Origin for the Twitch Extension panel's cross-origin requests to
# /extension/*, GET /static/* (sprite assets), and GET /card/<username>/image
# — see _extension_cors_headers() in app.py. Supports one '*' wildcard
# segment; the default matches any extension-id subdomain Twitch assigns a
# released extension's panel iframe.
EXTENSION_CORS_ORIGIN=https://*.ext-twitch.tv

# Set to "true" to additionally allow https://localhost:8080 (the Twitch
# Developer Rig's Local Test origin) through the CORS check above. Opt-in
# only — leave unset in production. Never set this on a deployed instance;
# it exists solely so a developer running the Rig locally can hit a real
# backend during Local Test.
EXTENSION_ALLOW_LOCAL_TEST=
