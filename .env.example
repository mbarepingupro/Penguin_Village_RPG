# Copy to .env and fill in real values. Loaded via python-dotenv (load_dotenv()) in app.py.

# Flask session signing key
SECRET_KEY=change-me

# Twitch OAuth (login) + Helix API (islive / stream presence)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=
# App access token used for server-to-server Helix calls (GET /islive, _stream_is_live()).
TWITCH_APP_TOKEN=

# Discord OAuth (login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Mayor dashboard access key (query/body "key" param, see _is_mayor_authed())
MAYOR_KEY=

# Shared secret for admin-only routes (e.g. /titles/grant), sent as the
# X-Admin-Secret header.
ADMIN_SECRET=

# Shared secret StreamerBot must send as the X-StreamerBot-Secret header on
# POST /seals/award, POST /stream/presence, and POST /stream/chatted. Must
# match exactly whatever value StreamerBot's outgoing HTTP action is
# configured to send in that header — these routes are otherwise open to
# anyone who can reach the server.
STREAMERBOT_SECRET=
